# Syzygy Rosetta Sandbox — Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration
# =============================================================================

# LLM Provider: gemini or mock
LLM_PROVIDER=gemini

# Google AI API key (Gemini / Gemma via same Generative Language API)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model id (default: Gemma 3 27B; override with e.g. gemini-2.0-flash, gemini-2.5-flash)
GEMINI_MODEL=gemma-3-27b-it

# GCP Project ID (optional, for Vertex AI)
GCP_PROJECT_ID=your-gcp-project-id

# GCP Region
GCP_LOCATION=us-central1

# =============================================================================
# Rosetta Governance Configuration
# =============================================================================

# Rosetta API URL
# Local: http://localhost:8000
# Cloud Run: https://syzygy-rosetta-738890830122.us-east1.run.app 
ROSETTA_URL=https://syzygy-rosetta-738890830122.us-east1.run.app 

# =============================================================================
# Application Settings
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Log Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
