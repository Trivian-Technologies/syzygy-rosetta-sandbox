# Copy this file to deploy/gcp.env and fill values.
# This file is for local machine use only. Do NOT commit real secrets.

# ===== Required deployment target =====
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
SERVICE_NAME=rosetta-sandbox

# ===== Runtime model/config =====
GEMINI_MODEL=mock
ROSETTA_URL=https://your-rosetta-service-url

# ===== Secret source (local only) =====
# This key is uploaded to GCP Secret Manager as gemini-api-key.
GEMINI_API_KEY=your_gemini_api_key
